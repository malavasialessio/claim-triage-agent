# AWS Bedrock credentials (usa il profilo configurato in AWS CLI)
AWS_PROFILE=bootcamp
AWS_REGION=us-west-2

# Modelli Bedrock
BEDROCK_MODEL_AGENT=anthropic.claude-sonnet-4-6
BEDROCK_MODEL_FAST=anthropic.claude-3-5-haiku-20241022-v1:0

# Backend
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Database
DATABASE_URL=sqlite:///./claim_triage.db

# Self-improving loop
FEEDBACK_REFRESH_THRESHOLD=10
MAX_RETRY_ATTEMPTS=3
CONFIDENCE_THRESHOLD=0.5
